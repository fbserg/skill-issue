#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.13"
# dependencies = ["pyrage>=1.2", "httpx>=0.28"]
# ///
"""Encrypt/decrypt .env using age + GitHub SSH keys.

Usage:
    secrets encrypt [--yes] [--allow-missing]
    secrets decrypt [--print] [--force] [--key PATH] [--key-cmd CMD] [--key-arg ARG ...]

encrypt:
    Fetches all push/admin collaborators from the current repo, resolves their
    GitHub SSH keys, and encrypts .env → .env.age.  Also writes .env.age.recipients
    (commit alongside .env.age so recipient-set changes are visible in diffs).

decrypt:
    Decrypts .env.age using your SSH private key.  Writes .env by default;
    --print sends plaintext to stdout instead.
"""

from __future__ import annotations

import argparse
import hashlib
import os
import shutil
import subprocess
import sys
import time
from pathlib import Path

import httpx
import pyrage
from pyrage import ssh

# ---------------------------------------------------------------------------
# Repo root (S1): derive from git, not __file__, so the script works anywhere
# on PATH and still operates on the *current* repo.
# ---------------------------------------------------------------------------

def get_git_root() -> Path:
    result = subprocess.run(
        ["git", "rev-parse", "--show-toplevel"],
        capture_output=True, text=True,
    )
    if result.returncode != 0:
        print("ERROR: not inside a git repository", file=sys.stderr)
        sys.exit(1)
    return Path(result.stdout.strip())


ROOT = get_git_root()
ENV_FILE = ROOT / ".env"
AGE_FILE = ROOT / ".env.age"
RECIPIENTS_FILE = ROOT / ".env.age.recipients"

DEFAULT_SSH_KEY_PATHS = [
    Path.home() / ".ssh" / "id_ed25519",
    Path.home() / ".ssh" / "id_rsa",
]

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

def fingerprint(pubkey_str: str) -> str:
    """First 8 hex chars of sha256 of the normalized public key string."""
    digest = hashlib.sha256(pubkey_str.strip().encode()).hexdigest()
    return digest[:8]


def key_type(pubkey_str: str) -> str:
    """Extract the key type token from a public key line."""
    return pubkey_str.strip().split()[0]


def is_tty() -> bool:
    return sys.stdout.isatty() and sys.stderr.isatty()


# ---------------------------------------------------------------------------
# Repo slug
# ---------------------------------------------------------------------------

def get_repo_slug() -> str:
    result = subprocess.run(
        ["gh", "repo", "view", "--json", "nameWithOwner", "-q", ".nameWithOwner"],
        capture_output=True, text=True, check=True, cwd=ROOT,
    )
    return result.stdout.strip()


# ---------------------------------------------------------------------------
# Collaborators (S2): paginated, push/admin only; (S3): drop bots
# ---------------------------------------------------------------------------

def get_collaborators(repo: str) -> list[str]:
    """Return logins with push or admin permission; exclude bot accounts."""
    result = subprocess.run(
        [
            "gh", "api",
            f"repos/{repo}/collaborators",
            "--paginate",
            "--jq", '.[] | select((.permissions.push==true) or (.permissions.admin==true)) | .login',
        ],
        capture_output=True, text=True, check=True,
    )
    all_logins = [line.strip() for line in result.stdout.splitlines() if line.strip()]

    # S3: exclude bot accounts (logins ending with [bot])
    bots = [login for login in all_logins if login.endswith("[bot]")]
    if bots:
        print(f"  excluding bots: {', '.join(bots)}", file=sys.stderr)

    return [login for login in all_logins if not login.endswith("[bot]")]


# ---------------------------------------------------------------------------
# SSH key fetch (S6: weak-key warning; S12: retry once on transient failure)
# ---------------------------------------------------------------------------

def fetch_ssh_keys(username: str) -> list[str]:
    """Fetch ed25519/rsa public keys for a GitHub user.  Retries once on failure."""
    url = f"https://github.com/{username}.keys"
    last_exc: Exception | None = None
    for attempt in range(2):
        try:
            resp = httpx.get(url, timeout=10)
            resp.raise_for_status()
            keys = [
                line.strip()
                for line in resp.text.strip().splitlines()
                if line.strip().startswith(("ssh-ed25519", "ssh-rsa"))
            ]
            # S6: warn about weak rsa keys
            for key in keys:
                if key_type(key) == "ssh-rsa":
                    print(
                        f"  WARNING: {username} uses ssh-rsa — ed25519 is preferred; rsa is the weak link",
                        file=sys.stderr,
                    )
            return keys
        except (httpx.HTTPError, httpx.TransportError) as exc:
            last_exc = exc
            if attempt == 0:
                print(f"  transient error fetching keys for {username}, retrying…", file=sys.stderr)
                time.sleep(1)
    # Hard failure after retry
    print(f"ERROR: could not fetch SSH keys for {username}: {last_exc}", file=sys.stderr)
    sys.exit(1)


# ---------------------------------------------------------------------------
# Recipient collection
# ---------------------------------------------------------------------------

# Holds resolved data per collaborator so we can show the confirmation table
# and write the manifest without re-fetching.
class RecipientEntry:
    def __init__(self, login: str, pubkey: str) -> None:
        self.login = login
        self.pubkey = pubkey
        self.ktype = key_type(pubkey)
        self.fp = fingerprint(pubkey)
        self.recipient = ssh.Recipient.from_str(pubkey)


def collect_recipient_entries(allow_missing: bool) -> list[RecipientEntry]:
    repo = get_repo_slug()
    collaborators = get_collaborators(repo)
    print(f"repo: {repo}", file=sys.stderr)
    print(f"collaborators ({len(collaborators)}): {', '.join(collaborators)}", file=sys.stderr)

    entries: list[RecipientEntry] = []
    missing: list[str] = []

    for login in collaborators:
        keys = fetch_ssh_keys(login)
        if not keys:
            missing.append(login)
            print(f"  {login}: no usable SSH key on GitHub", file=sys.stderr)
            continue
        for pubkey in keys:
            entries.append(RecipientEntry(login, pubkey))

    # S7: refuse to encrypt if any collaborator would be dropped, unless --allow-missing
    if missing:
        msg = f"  would be dropped (no key): {', '.join(missing)}"
        if allow_missing:
            print(f"  WARNING: {msg}", file=sys.stderr)
        else:
            print(
                f"ERROR: {msg}\n"
                "  Re-encrypt would exclude these collaborators.  Options:\n"
                "    - Ask them to add an ed25519 key to GitHub, then retry.\n"
                "    - Pass --allow-missing to encrypt anyway (they cannot decrypt).",
                file=sys.stderr,
            )
            sys.exit(1)

    if not entries:
        print("ERROR: no SSH keys found for any collaborator", file=sys.stderr)
        sys.exit(1)

    return entries


# ---------------------------------------------------------------------------
# Recipient confirmation (S4)
# ---------------------------------------------------------------------------

def confirm_recipients(entries: list[RecipientEntry], yes: bool) -> None:
    """Print recipient table; require y/N on a TTY unless --yes."""
    print("\nRecipients:", file=sys.stderr)
    for e in entries:
        print(f"  {e.login:<20}  {e.ktype:<15}  {e.fp}", file=sys.stderr)

    if yes or not is_tty():
        return

    try:
        answer = input("\nEncrypt for these recipients? [y/N] ").strip().lower()
    except (EOFError, KeyboardInterrupt):
        print("\nAborted.", file=sys.stderr)
        sys.exit(1)

    if answer != "y":
        print("Aborted.", file=sys.stderr)
        sys.exit(1)


# ---------------------------------------------------------------------------
# gitignore guard (S11)
# ---------------------------------------------------------------------------

def check_env_not_tracked() -> None:
    """Refuse to encrypt if .env is tracked by git or not in .gitignore."""
    # Check if .env is tracked
    tracked = subprocess.run(
        ["git", "ls-files", "--error-unmatch", str(ENV_FILE)],
        capture_output=True, cwd=ROOT,
    )
    if tracked.returncode == 0:
        print(
            "ERROR: .env is tracked by git — remove it from the index first:\n"
            "  git rm --cached .env\n"
            "  echo '.env' >> .gitignore",
            file=sys.stderr,
        )
        sys.exit(1)

    # Check if .env is gitignored
    ignored = subprocess.run(
        ["git", "check-ignore", str(ENV_FILE)],
        capture_output=True, cwd=ROOT,
    )
    if ignored.returncode != 0:
        print(
            "ERROR: .env is not listed in .gitignore — add it before encrypting:\n"
            "  echo '.env' >> .gitignore",
            file=sys.stderr,
        )
        sys.exit(1)


# ---------------------------------------------------------------------------
# C2: recipient-set drift detection
# ---------------------------------------------------------------------------

def manifest_drift(
    old_lines: list[str], new_lines: list[str]
) -> tuple[set[str], set[str]]:
    """Return (added, removed) sets of manifest lines between two encrypts."""
    old = set(old_lines)
    new = set(new_lines)
    return new - old, old - new


# ---------------------------------------------------------------------------
# Encrypt command
# ---------------------------------------------------------------------------

def cmd_encrypt(yes: bool, allow_missing: bool) -> None:
    if not ENV_FILE.exists():
        print(f"ERROR: {ENV_FILE} not found", file=sys.stderr)
        sys.exit(1)

    # S11: gitignore guard
    check_env_not_tracked()

    entries = collect_recipient_entries(allow_missing)

    # C2: warn loudly if the recipient set changed since the last encrypt
    manifest_lines = sorted(f"{e.login}: {e.fp}" for e in entries)
    if RECIPIENTS_FILE.exists():
        old_lines = [
            line for line in RECIPIENTS_FILE.read_text().splitlines() if line.strip()
        ]
        added, removed = manifest_drift(old_lines, manifest_lines)
        if added or removed:
            print("\n⚠ recipient set CHANGED since last encrypt:", file=sys.stderr)
            for line in sorted(added):
                print(f"  + added:   {line}", file=sys.stderr)
            for line in sorted(removed):
                print(f"  - removed: {line}", file=sys.stderr)

    # S4: confirmation
    confirm_recipients(entries, yes)

    recipients = [e.recipient for e in entries]
    encrypted = pyrage.encrypt(ENV_FILE.read_bytes(), recipients)
    AGE_FILE.write_bytes(encrypted)

    # S9: chmod .env.age to 0o600
    AGE_FILE.chmod(0o600)

    # S5: write deterministic recipients manifest
    RECIPIENTS_FILE.write_text("\n".join(manifest_lines) + "\n")

    print(
        f"\nencrypted {ENV_FILE.name} → {AGE_FILE.name} ({len(recipients)} recipient key(s))\n"
        f"wrote {RECIPIENTS_FILE.name}\n"
        f"commit BOTH {AGE_FILE.name} and {RECIPIENTS_FILE.name} so the recipient set is visible in diffs.",
        file=sys.stderr,
    )


# ---------------------------------------------------------------------------
# SSH identity resolution
# ---------------------------------------------------------------------------

def find_ssh_identity(
    key_path: str | None = None,
    key_cmd: str | None = None,
    key_args: list[str] | None = None,
) -> ssh.Identity:
    if key_cmd:
        result = subprocess.run([key_cmd, *(key_args or [])], capture_output=True, check=True)
        return ssh.Identity.from_buffer(result.stdout)

    if key_path:
        path = Path(key_path).expanduser()
        if not path.exists():
            print(f"ERROR: key not found: {path}", file=sys.stderr)
            sys.exit(1)
        return ssh.Identity.from_buffer(path.read_bytes())

    for path in DEFAULT_SSH_KEY_PATHS:
        if path.exists():
            return ssh.Identity.from_buffer(path.read_bytes())

    print(
        "ERROR: no SSH private key found.\n"
        f"  searched: {', '.join(str(p) for p in DEFAULT_SSH_KEY_PATHS)}\n"
        "  hint: use --key <path> or --key-cmd <command>",
        file=sys.stderr,
    )
    sys.exit(1)


# ---------------------------------------------------------------------------
# Decrypt command
# ---------------------------------------------------------------------------

def cmd_decrypt(
    *,
    to_stdout: bool = False,
    force: bool = False,
    key_path: str | None = None,
    key_cmd: str | None = None,
    key_args: list[str] | None = None,
) -> None:
    if not AGE_FILE.exists():
        print(f"ERROR: {AGE_FILE} not found — run 'encrypt' first", file=sys.stderr)
        sys.exit(1)

    identity = find_ssh_identity(key_path, key_cmd, key_args)
    plaintext = pyrage.decrypt(AGE_FILE.read_bytes(), [identity])

    if to_stdout:
        sys.stdout.buffer.write(plaintext)
        return

    # S8: no-clobber — backup if .env exists and differs
    if ENV_FILE.exists():
        existing = ENV_FILE.read_bytes()
        if existing == plaintext:
            print(f"{ENV_FILE.name} is already up to date — nothing to do.", file=sys.stderr)
            return
        if not force:
            bak = ENV_FILE.with_suffix(".bak")
            shutil.copy2(ENV_FILE, bak)
            print(f"  existing .env differed — backed up to {bak.name}", file=sys.stderr)

    ENV_FILE.write_bytes(plaintext)

    # S9: chmod .env to 0o600
    ENV_FILE.chmod(0o600)

    print(f"decrypted {AGE_FILE.name} → {ENV_FILE.name} (mode 600)", file=sys.stderr)


# ---------------------------------------------------------------------------
# Argument parsing (S10)
# ---------------------------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="secrets",
        description="Encrypt/decrypt .env using age + GitHub SSH keys.",
    )
    sub = parser.add_subparsers(dest="command", required=True)

    enc = sub.add_parser("encrypt", help="Encrypt .env → .env.age for all repo collaborators")
    enc.add_argument(
        "--yes", action="store_true",
        help="Skip interactive recipient confirmation (for CI)",
    )
    enc.add_argument(
        "--allow-missing", action="store_true",
        help="Encrypt even if some collaborators have no usable SSH key (they won't be able to decrypt)",
    )

    dec = sub.add_parser("decrypt", help="Decrypt .env.age → .env (or stdout)")
    dec.add_argument("--print", dest="to_stdout", action="store_true", help="Write plaintext to stdout instead of .env")
    dec.add_argument("--force", action="store_true", help="Overwrite .env without backing it up")
    dec.add_argument("--key", dest="key_path", metavar="PATH", help="Path to SSH private key")
    dec.add_argument("--key-cmd", metavar="CMD", help="Command that outputs the SSH private key on stdout")
    dec.add_argument(
        "--key-arg", dest="key_args", metavar="ARG", action="append", default=[],
        help="Argument(s) for --key-cmd (repeatable)",
    )

    return parser


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()

    if args.command == "encrypt":
        cmd_encrypt(yes=args.yes, allow_missing=args.allow_missing)
    elif args.command == "decrypt":
        cmd_decrypt(
            to_stdout=args.to_stdout,
            force=args.force,
            key_path=args.key_path,
            key_cmd=args.key_cmd,
            key_args=args.key_args or [],
        )


if __name__ == "__main__":
    main()
